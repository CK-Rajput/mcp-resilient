# Copy this file to .env and fill in your actual values
# NEVER commit .env file to git!

# Your LLM API key (Claude, GPT, or your internal LLM provider)
LLM_API_KEY=sk-prod-your-token-here

# Your tenant ID  (Your organization ID or project name)
TENANT_ID=your_tenant_id 

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Monitoring/Observability
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=8000

# Optional: Database for rate limits
RATE_LIMIT_DB_URL=redis://localhost:6379

# Optional: Auth service
AUTH_SERVICE_URL=https://auth.example.com
AUTH_SERVICE_KEY=your-auth-service-key
